import { useState } from 'react';
import { useAuth } from '../context/AuthContext';
import { api } from '../lib/api';
import Layout from '../components/Layout';
import { Button } from '../components/ui/button';
import { Input } from '../components/ui/input';
import { Label } from '../components/ui/label';
import { Textarea } from '../components/ui/textarea';
import { toast } from 'sonner';
import { Copy, ExternalLink } from 'lucide-react';

export default function Settings() {
  const { user, identity, refreshIdentity } = useAuth();
  const [saving, setSaving] = useState(false);
  const [bio, setBio] = useState(identity?.bio || '');

  const copyToClipboard = (text) => {
    navigator.clipboard.writeText(text);
    toast.success('Copied to clipboard');
  };

  const saveBio = async () => {
    if (!identity) return;
    
    setSaving(true);
    try {
      // Note: Would need to add an endpoint for updating identity bio
      toast.success('Profile updated');
      refreshIdentity();
    } catch (error) {
      toast.error('Failed to save');
    } finally {
      setSaving(false);
    }
  };

  const publicUrl = identity ? `${window.location.origin}/r/${identity.handle}` : '';

  return (
    <Layout>
      <div className="max-w-2xl space-y-8 animate-in">
        <div>
          <h1 className="text-3xl font-serif mb-1">Settings</h1>
          <p className="text-muted-foreground">
            Manage your Reach identity
          </p>
        </div>

        {/* Account Info */}
        <div className="form-section">
          <h2 className="text-lg font-serif mb-4">Account</h2>
          <div className="space-y-4">
            <div className="space-y-2">
              <Label>Name</Label>
              <Input
                value={user?.name || ''}
                disabled
                className="rounded-none bg-muted"
              />
            </div>
            <div className="space-y-2">
              <Label>Email</Label>
              <Input
                value={user?.email || ''}
                disabled
                className="rounded-none bg-muted"
              />
            </div>
          </div>
        </div>

        {/* Identity */}
        {identity && (
          <div className="form-section">
            <h2 className="text-lg font-serif mb-4">Identity</h2>
            <div className="space-y-4">
              <div className="space-y-2">
                <Label>Handle</Label>
                <div className="flex items-center gap-2">
                  <Input
                    value={identity.handle}
                    disabled
                    className="rounded-none bg-muted mono"
                  />
                </div>
                <p className="text-xs text-muted-foreground">
                  Your handle cannot be changed.
                </p>
              </div>

              <div className="space-y-2">
                <Label>Bio</Label>
                <Textarea
                  value={bio}
                  onChange={(e) => setBio(e.target.value)}
                  placeholder="Tell people about yourself..."
                  className="rounded-none resize-none"
                  rows={3}
                  data-testid="settings-bio"
                />
              </div>

              <div className="space-y-2">
                <Label>Type</Label>
                <Input
                  value={identity.type}
                  disabled
                  className="rounded-none bg-muted capitalize"
                />
              </div>
            </div>
          </div>
        )}

        {/* Public Link */}
        {identity && (
          <div className="form-section">
            <h2 className="text-lg font-serif mb-4">Public Link</h2>
            <div className="flex items-center gap-2">
              <Input
                value={publicUrl}
                readOnly
                className="rounded-none mono text-sm"
                data-testid="public-url"
              />
              <Button
                variant="outline"
                size="icon"
                onClick={() => copyToClipboard(publicUrl)}
                className="rounded-none flex-shrink-0"
                data-testid="copy-url-btn"
              >
                <Copy className="w-4 h-4" />
              </Button>
              <a href={publicUrl} target="_blank" rel="noopener noreferrer">
                <Button
                  variant="outline"
                  size="icon"
                  className="rounded-none flex-shrink-0"
                  data-testid="open-url-btn"
                >
                  <ExternalLink className="w-4 h-4" />
                </Button>
              </a>
            </div>
            <p className="text-xs text-muted-foreground mt-2">
              Share this link to let people reach you.
            </p>
          </div>
        )}

        {/* Member Since */}
        <div className="pt-4">
          <p className="text-sm text-muted-foreground">
            Member since {new Date(user?.created_at).toLocaleDateString()}
          </p>
        </div>
      </div>
    </Layout>
  );
}
